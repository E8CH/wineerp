# wineerp backend — 환경변수 예시 (값 없이 이름만). 실제 값은 .env(커밋 금지)에.
# ⚠️ LLM 키는 반드시 Billing 활성화된 유료 티어 계정을 사용할 것
#    (무료 Gemini는 고객 데이터를 학습·사람 검토에 사용 — 고객사 설명 불가).

PROJECT_NAME=wineerp
ENVIRONMENT=local
API_V1_PREFIX=/api/v1

# 보안 (Story 1.3+)
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 데이터베이스 (Story 1.2+; 로컬 미설정 시 health는 동작)
# 예) postgresql+psycopg://user:pass@localhost:5432/wineerp
DATABASE_URL=

# LLM (Story 3.1; 유료 티어 필수)
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=

# 오브젝트 스토리지 R2 (Story 2.3)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
